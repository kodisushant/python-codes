   "source": [
    "def sum_multiples(n, k):\n",
    "    m = (n - 1) // k\n",
    "    return k * m * (m + 1) // 2\n",
    "\n",
    "T = int(input())\n",
    "for _ in range(T):\n",
    "    N = int(input())\n",
    "    print(sum_multiples(N, 3) + sum_multiples(N, 5) - sum_multiples(N, 15))"
   ]
